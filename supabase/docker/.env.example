# ---------------------------------------------------------------------------------------------------------------------
# SUPABASE DOKPLOY CONFIGURATION - COMPLETE STACK
# ---------------------------------------------------------------------------------------------------------------------
# These variables should be added to your Dokploy Environment Variables section.
# Use the `scripts/generate-secrets.js` to generate secure values for the keys.
# ---------------------------------------------------------------------------------------------------------------------

# --- SECRETS & KEYS (Generate these!) ---
POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
SECRET_KEY_BASE=
VAULT_ENC_KEY=
PG_META_CRYPTO_KEY=

# --- DATABASE ---
POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# --- SUPAVISOR (Connection Pooler) ---
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=contaflow
POOLER_DB_POOL_SIZE=5

# --- KONG (API Gateway) ---
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# --- POSTGREST ---
PGRST_DB_SCHEMAS=public,storage,graphql_public

# --- AUTH (GoTrue) ---
SITE_URL=https://contaflow.bnex.cloud
ADDITIONAL_REDIRECT_URLS=https://contaflow.bnex.cloud/**,http://localhost:3000/**
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=https://supabase-contaflow-744afe27d149c9e2.bnex.cloud

MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@bnex.cloud
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
SMTP_SENDER_NAME=ContaFlow
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# --- STUDIO ---
STUDIO_DEFAULT_ORGANIZATION=ContaFlow
STUDIO_DEFAULT_PROJECT=ContaFlow-Prod
SUPABASE_PUBLIC_URL=https://supabase-contaflow-744afe27d149c9e2.bnex.cloud
IMGPROXY_ENABLE_WEBP_DETECTION=true
OPENAI_API_KEY=

# --- EDGE FUNCTIONS ---
FUNCTIONS_VERIFY_JWT=false

# --- LOGS / ANALYTICS (Logflare) ---
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# --- GCP (Optional - for BigQuery analytics backend) ---
GOOGLE_PROJECT_ID=
GOOGLE_PROJECT_NUMBER=
